---
import LanguageToggle from './LanguageToggle.astro';

interface Props {
  lang: string;
  nav: {
    about: string;
    works: string;
    exhibitions: string;
    contact: string;
  };
}

const { lang, nav } = Astro.props;
---

<header class="header" id="header">
  <div class="header-inner">
    <a href={lang === 'fr' ? '/' : '/en/'} class="header-logo">
      <span class="logo-studio">Studio</span>
      <span class="logo-infanti">Infanti</span>
    </a>
    <nav class="header-nav" aria-label="Main navigation">
      <a href="#about">{nav.about}</a>
      <a href="#works">{nav.works}</a>
      <a href="#exhibitions">{nav.exhibitions}</a>
      <a href="#contact">{nav.contact}</a>
      <LanguageToggle lang={lang} />
    </nav>
    <button class="menu-toggle" aria-label="Menu" aria-expanded="false">
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 var(--space-md);
    height: var(--header-height);
    transition: background-color 0.3s ease, backdrop-filter 0.3s ease;
  }

  .header.scrolled {
    background-color: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(10px);
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .header-logo {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-decoration: none;
    padding: 0.2em 0;
    gap: 0;
    transition: opacity 0.3s ease;
  }

  .header-logo:hover {
    opacity: 0.8;
  }

  .header-logo:hover .logo-studio {
    text-shadow: 0 0 8px rgba(200, 170, 110, 0.4);
  }

  .logo-studio {
    font-family: var(--font-body);
    font-size: 0.55rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-accent);
    line-height: 1;
    transition: text-shadow 0.3s ease;
  }

  .logo-infanti {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--color-text);
    letter-spacing: 0.04em;
    line-height: 1;
    margin-top: 0.1em;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .header-nav a {
    font-size: 0.875rem;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: color 0.3s ease;
  }

  .header-nav a:hover {
    color: var(--color-text);
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    flex-direction: column;
    gap: 6px;
  }

  .menu-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .menu-toggle[aria-expanded="true"] span:first-child {
    transform: translateY(4px) rotate(45deg);
  }

  .menu-toggle[aria-expanded="true"] span:last-child {
    transform: translateY(-4px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .menu-toggle {
      display: flex;
    }

    .header-nav {
      position: fixed;
      top: var(--header-height);
      left: 0;
      right: 0;
      bottom: 0;
      flex-direction: column;
      justify-content: center;
      gap: var(--space-lg);
      background: rgba(10, 10, 10, 0.98);
      backdrop-filter: blur(20px);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease, visibility 0.3s ease;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }

    .header-nav.open {
      opacity: 1;
      visibility: visible;
    }

    .header-nav a {
      font-size: 1.25rem;
    }
  }
</style>

<script>
  function initHeader() {
    const header = document.getElementById('header');
    const toggle = document.querySelector('.menu-toggle');
    const nav = document.querySelector('.header-nav');

    if (!header || !toggle || !nav) return;

    // Scroll effect
    const onScroll = () => {
      header.classList.toggle('scrolled', window.scrollY > 50);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Mobile menu
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      nav.classList.toggle('open');
      document.body.style.overflow = expanded ? '' : 'hidden';
    });

    // Close on nav link click
    nav.querySelectorAll('a[href^="#"]').forEach((link) => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        nav.classList.remove('open');
        document.body.style.overflow = '';
      });
    });
  }

  initHeader();
</script>
