---
interface Props {
  lang: string;
}

const { lang } = Astro.props;
const otherLang = lang === 'fr' ? 'en' : 'fr';
const otherPath = lang === 'fr' ? '/en' : '/';
---

<a href={otherPath} class="lang-toggle" aria-label={`Switch to ${otherLang === 'en' ? 'English' : 'Français'}`}>
  <svg class="lang-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
  </svg>
  {otherLang.toUpperCase()}
</a>

<style>
  .lang-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    padding: 0.25rem 0.5rem;
    border-radius: 2px;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .lang-toggle:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }
</style>
