---
interface Props {
  content: {
    title: string;
    email: string;
    phone: string;
    followUs: string;
    copyright: string;
    ecoDesigned: string;
  };
}

const { content } = Astro.props;
---

<footer class="contact" id="contact">
  <div class="container">
    <div class="contact-inner reveal">
      <div class="contact-main">
        <h2 class="section-title">{content.title}</h2>
        <div class="contact-details">
          <a href={`mailto:${content.email}`} class="contact-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2" />
              <path d="M22 4L12 13L2 4" />
            </svg>
            <span>{content.email}</span>
          </a>
          <a href="tel:+32496042690" class="contact-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
            <span>{content.phone}</span>
          </a>
        </div>
      </div>

      <div class="contact-social">
        <span class="social-label">{content.followUs}</span>
        <div class="social-links">
          <a href="https://www.instagram.com/margot.infanti/" target="_blank" rel="noopener noreferrer" aria-label="Instagram — Margot">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" />
              <circle cx="12" cy="12" r="5" />
              <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none" />
            </svg>
            <span>Margot</span>
          </a>
          <a href="https://www.instagram.com/louise_infanti/" target="_blank" rel="noopener noreferrer" aria-label="Instagram — Louise">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" />
              <circle cx="12" cy="12" r="5" />
              <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none" />
            </svg>
            <span>Louise</span>
          </a>
          <a href="https://www.tiktok.com/@inf.sisters" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5" />
            </svg>
            <span>TikTok</span>
          </a>
        </div>
      </div>
    </div>

    <div class="contact-bottom">
      <p>{content.copyright}</p>
      <div class="contact-credits">
        <p class="contact-eco">
          <a href="https://www.ecoindex.fr/resultat/?id=fca44c0d-8044-4611-be7b-566d5c601c93" target="_blank" rel="noopener noreferrer">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66l.95-2.3c.48.17.98.3 1.34.3C19 20 22 3 22 3c-1 2-8 2.25-13 3.25S2 11.5 2 13.5s1.75 3.75 1.75 3.75" />
            </svg>
            {content.ecoDesigned}
          </a>
        </p>
        <p class="contact-credit">
          <a href="https://pwablo.be/" target="_blank" rel="noopener noreferrer">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="16 18 22 12 16 6" />
              <polyline points="8 6 2 12 8 18" />
            </svg>
            developed by pwablo.be
          </a>
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .contact {
    padding: var(--space-xl) var(--space-md);
    background: var(--color-bg);
    border-top: 1px solid rgba(212, 168, 83, 0.08);
  }

  .contact-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .contact-details {
    display: flex;
    flex-direction: row;
    gap: var(--space-md);
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text);
    transition: color 0.3s ease;
  }

  .contact-link:hover {
    color: var(--color-accent);
  }

  .contact-link svg {
    flex-shrink: 0;
    opacity: 0.6;
  }

  .contact-link:hover svg {
    opacity: 1;
  }

  .contact-social {
    align-self: center;
  }

  .social-label {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: var(--space-sm);
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .social-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    transition: color 0.3s ease;
  }

  .social-links a:hover {
    color: var(--color-accent);
  }

  .contact-bottom {
    margin-top: var(--space-md);
    padding-top: var(--space-sm);
    border-top: 1px solid rgba(245, 240, 232, 0.05);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .contact-bottom p {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.05em;
  }

  .contact-credits {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .contact-eco a,
  .contact-credit a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: rgba(212, 168, 83, 0.72);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.3s ease;
  }

  .contact-eco a:hover,
  .contact-credit a:hover {
    color: rgba(212, 168, 83, 0.9);
  }

  .contact-eco svg,
  .contact-credit svg {
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .contact {
      padding: var(--space-lg) var(--space-sm);
    }

    .contact-inner {
      flex-direction: column;
      gap: var(--space-lg);
    }

    .contact-social {
      align-self: flex-start;
      width: 100%;
    }

    .contact-details {
      flex-direction: column;
      gap: var(--space-sm);
    }

    .contact-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }
</style>
