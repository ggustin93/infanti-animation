---
import WorkCard from './WorkCard.astro';
import VideoModal from './VideoModal.astro';
import { works } from '../data/works';

interface Props {
  lang: string;
  content: {
    title: string;
    viewWork: string;
    seeAll: string;
  };
}

const { lang, content } = Astro.props;
const locale = lang as 'fr' | 'en';
---

<section class="works" id="works">
  <div class="container">
    <h2 class="section-title reveal">{content.title}</h2>

    <div class="works-grid">
      {works.filter(w => w.featured).map((work, index) => (
        <WorkCard
          id={work.id}
          title={work.title[locale]}
          description={work.description[locale]}
          thumbnail={work.thumbnail}
          video={work.video}
          externalUrl={work.externalUrl}
          year={work.year}
          index={index}
          viewWorkLabel={content.viewWork}
        />
      ))}
    </div>

    <div class="works-footer">
      <a href={lang === 'fr' ? '/works' : '/en/works'} class="works-see-all">
        {content.seeAll}
      </a>
    </div>

    <VideoModal />
  </div>
</section>

<style>
  .works {
    background: var(--color-bg);
  }

  .works-footer {
    text-align: center;
    padding-top: var(--space-lg);
  }

  .works-see-all {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    padding-bottom: 2px;
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  .works-see-all:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .works-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .works-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }
  }
</style>
